# Sao chép file này thành `.env` rồi điền giá trị thật. KHÔNG commit `.env`.

# Bật backend LLM thật (để trống hoặc =mock sẽ dùng mock runtime cho autograde)
REFLEXION_BACKEND=llm

# Thông tin từ ckey.vn (OpenAI-compatible gateway)
OPENAI_API_KEY=your_ckey_vn_api_key
OPENAI_BASE_URL=https://api.ckey.vn/v1
OPENAI_MODEL=gpt-5.4-mini

# Tùy chọn
OPENAI_TIMEOUT=60
OPENAI_MAX_RETRIES=4
